name: Check and Push AUR Update

on:
  schedule:
    # 每三天 UTC 8:01 检查
    - cron: '1 8 1/3 * *'
  # 支持手动触发
  workflow_dispatch:

jobs:
  update-aur:
    runs-on: ubuntu-latest
    container:
      image: archlinux:latest
    steps:
      - name: Install dependencies
        run: |
          pacman -Syu --noconfirm
          pacman -S --noconfirm base-devel git openssh curl

      - name: Setup SSH key for AUR
        env:
          AUR_SSH_PRIVATE_KEY: ${{ secrets.AUR_SSH_PRIVATE_KEY }}
        run: |
          mkdir -p ~/.ssh
          echo "$AUR_SSH_PRIVATE_KEY" > ~/.ssh/aur_key
          chmod 600 ~/.ssh/aur_key
          ssh-keyscan aur.archlinux.org >> ~/.ssh/known_hosts
          echo "Host aur.archlinux.org" > ~/.ssh/config
          echo "  IdentityFile ~/.ssh/aur_key" >> ~/.ssh/config
          echo "  User aur" >> ~/.ssh/config

      - name: Clone AUR repo
        run: |
          git clone aur@aur.archlinux.org:connectiq-sdk-manager.git /tmp/aur-repo
          cd /tmp/aur-repo
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"

      - name: Get current PKGBUILD values
        id: current
        run: |
          cd /tmp/aur-repo
          echo "CURRENT_VERSION=$(grep -oP 'pkgver=\K.*' PKGBUILD)" >> $GITHUB_ENV
          echo "CURRENT_SHA256=$(grep -oP "sha256sums='\K[^']*" PKGBUILD)" >> $GITHUB_ENV

      - name: Scrape latest SDK version from Garmin
        id: garmin
        run: |
          VERSION=$(curl -sL "https://developer.garmin.com/connect-iq/sdk/" | \
            grep -oP 'Connect IQ \K\d+\.\d+\.\d+' | head -1)
          echo "SDK_VERSION=$VERSION" >> $GITHUB_ENV
          echo "version=$VERSION" >> $GITHUB_OUTPUT

      - name: Download SDK Manager & compute SHA256
        id: download
        run: |
          curl -sL -o /tmp/sdkmanager.zip \
            "https://developer.garmin.com/downloads/connect-iq/sdk-manager/connectiq-sdk-manager-linux.zip"
          NEW_SHA256=$(sha256sum /tmp/sdkmanager.zip | cut -d' ' -f1)
          echo "NEW_SHA256=$NEW_SHA256" >> $GITHUB_ENV
          echo "sha256=$NEW_SHA256" >> $GITHUB_OUTPUT

      - name: Compare and decide
        id: check
        run: |
          if [ "$NEW_SHA256" != "$CURRENT_SHA256" ]; then
            # 哈希变了 → 二进制有变动，需要人工审查
            echo "❌ SDK Manager binary hash changed!"
            echo "   Old SHA256: $CURRENT_SHA256"
            echo "   New SHA256: $NEW_SHA256"
            echo "   Version: $CURRENT_VERSION → $SDK_VERSION"
            echo ""
            echo "Manual review required: check deps, patchelf, etc., then update AUR."
            exit 1
          elif [ "$SDK_VERSION" != "$CURRENT_VERSION" ]; then
            # 哈希没变，仅版本号更新 → 自动推进
            echo "UPDATE_NEEDED=true" >> $GITHUB_ENV
            echo "✅ Version bump: $CURRENT_VERSION → $SDK_VERSION"
          else
            echo "UPDATE_NEEDED=false" >> $GITHUB_ENV
            echo "✅ No update needed"
          fi

      - name: Update PKGBUILD and .SRCINFO
        if: env.UPDATE_NEEDED == 'true'
        run: |
          cd /tmp/aur-repo
          sed -i "s/pkgver=.*/pkgver=$SDK_VERSION/" PKGBUILD
          # hash 没变，不用改 sha256sums
          sed -i "s/pkgrel=.*/pkgrel=1/" PKGBUILD
          makepkg --printsrcinfo > .SRCINFO
          echo "✅ PKGBUILD and .SRCINFO updated"

      - name: Commit and push to AUR
        if: env.UPDATE_NEEDED == 'true'
        run: |
          cd /tmp/aur-repo
          git add PKGBUILD .SRCINFO
          git commit -m "Update to Connect IQ SDK $SDK_VERSION-1"
          git push
          echo "✅ Pushed to AUR: aur.archlinux.org/connectiq-sdk-manager.git"
